# Desafio de Replicacao

pacotes <- c("readxl", "dplyr", "tidyr", "stringr", "ggplot2", "readr", "tibble")
novos <- pacotes[!vapply(pacotes, requireNamespace, quietly = TRUE, FUN.VALUE = logical(1))]
if (length(novos) > 0) install.packages(novos)

library(readxl)
library(dplyr)
library(tidyr)
library(stringr)
library(ggplot2)
library(readr)
library(tibble)

dir.create("outputs", showWarnings = FALSE)
dir.create(file.path("outputs", "figuras"), recursive = TRUE, showWarnings = FALSE)

arquivo <- "base lista 3(1).xlsx"

# A planilha possui duas linhas de cabecalho.
bruta <- read_excel(arquivo, col_names = FALSE)
h1 <- as.character(unlist(bruta[1, ]))
h2 <- as.character(unlist(bruta[2, ]))
cabecalho <- ifelse(!is.na(h2) & str_trim(h2) != "", h2, h1)
cabecalho <- make.unique(cabecalho)

dados <- bruta[-c(1, 2), ]
names(dados) <- cabecalho

dados <- dados %>%
  mutate(across(everything(), ~ str_trim(as.character(.x)))) %>%
  mutate(across(everything(), ~ na_if(.x, "")))

# Nomes curtos por posicao, preservando o dicionario original.
dicionario <- tibble(posicao = seq_along(names(dados)), variavel_original = names(dados))
write_csv(dicionario, "outputs/dicionario_variaveis.csv")
names(dados) <- paste0("v", seq_len(ncol(dados)))

# Auditoria basica
resumo_base <- tibble(
  observacoes = nrow(dados),
  variaveis = ncol(dados),
  estados = n_distinct(dados$v2),
  duplicatas_codigo = sum(duplicated(dados$v1)),
  codigos_ausentes = sum(is.na(dados$v1)),
  estados_ausentes = sum(is.na(dados$v2))
)
write_csv(resumo_base, "outputs/resumo_base.csv")

# Funcoes auxiliares
sim <- function(x) !is.na(x) & x == "Sim"
selecionado <- function(x) !is.na(x)
satisfatorio <- function(x) x %in% c("Mais satisfatorio do que insatisfatorio",
                                      "Totalmente satisfatorio",
                                      "Mais satisfatório do que insatisfatório",
                                      "Totalmente satisfatório")

# Indicadores nacionais
dados <- dados %>%
  mutate(
    responsavel_area = !str_detect(coalesce(v8, ""), "^Nao existe|^Não existe"),
    area_especifica = str_detect(coalesce(v8, ""), "area/coordenação|área/coordenação"),
    investimento = sim(v9),
    dotacao = sim(v10),
    curriculo_especifico = str_detect(coalesce(v15, ""), "atencao especifica|atenção específica"),
    monitora_raca = sim(v28),
    alguma_formacao = if_any(v33:v36, ~ !is.na(.x)),
    material_especifico = !is.na(v38),
    governanca_conselho = sim(v69) | sim(v70) | sim(v71),
    apropriacao_secretaria = satisfatorio(v72),
    apropriacao_gestao = satisfatorio(v73),
    apropriacao_professores = satisfatorio(v74)
  )

indicadores <- dados %>%
  summarise(
    `Responsavel ou area` = mean(responsavel_area) * 100,
    `Investimento especifico` = mean(investimento) * 100,
    `Dotacao orcamentaria` = mean(dotacao) * 100,
    `Curriculo com atencao especifica` = mean(curriculo_especifico) * 100,
    `Monitoramento por raca` = mean(monitora_raca) * 100,
    `Alguma formacao` = mean(alguma_formacao) * 100,
    `Material especifico` = mean(material_especifico) * 100,
    `Governanca via conselho` = mean(governanca_conselho) * 100,
    `Apropriacao satisfatoria - secretaria` = mean(apropriacao_secretaria) * 100,
    `Apropriacao satisfatoria - gestao` = mean(apropriacao_gestao) * 100,
    `Apropriacao satisfatoria - professores` = mean(apropriacao_professores) * 100
  ) %>%
  pivot_longer(everything(), names_to = "indicador", values_to = "percentual")
write_csv(indicadores, "outputs/indicadores_nacionais.csv")

# Desafios selecionados (v75:v85)
desafios <- dados %>%
  summarise(across(v75:v85, ~ mean(!is.na(.x)) * 100)) %>%
  pivot_longer(everything(), names_to = "variavel", values_to = "percentual") %>%
  left_join(dicionario %>% mutate(variavel = paste0("v", posicao)), by = "variavel") %>%
  select(desafio = variavel_original, percentual) %>%
  arrange(desc(percentual))
write_csv(desafios, "outputs/desafios.csv")

# Indice principal e especificacao alternativa para robustness
dados <- dados %>%
  rowwise() %>%
  mutate(
    indice_amplo = mean(c(responsavel_area, investimento, dotacao,
                          curriculo_especifico, monitora_raca,
                          alguma_formacao, material_especifico,
                          governanca_conselho)) * 100,
    indice_estrito = mean(c(area_especifica, dotacao,
                            curriculo_especifico, monitora_raca,
                            sim(v70))) * 100
  ) %>%
  ungroup()

por_estado <- dados %>%
  group_by(estado = v2) %>%
  summarise(
    n = n(),
    indice_amplo = mean(indice_amplo),
    indice_estrito = mean(indice_estrito),
    .groups = "drop"
  ) %>%
  arrange(desc(indice_amplo))
write_csv(por_estado, "outputs/indices_por_estado.csv")

robustez <- tibble(
  correlacao_indices = cor(por_estado$indice_amplo, por_estado$indice_estrito,
                           use = "complete.obs", method = "spearman")
)
write_csv(robustez, "outputs/robustez.csv")

# Graficos
g1 <- indicadores %>%
  arrange(percentual) %>%
  ggplot(aes(x = reorder(indicador, percentual), y = percentual)) +
  geom_col() +
  coord_flip() +
  labs(x = NULL, y = "% dos respondentes",
       title = "Indicadores de institucionalizacao da politica") +
  theme_minimal(base_size = 11)
ggsave("outputs/figuras/indicadores_nacionais.png", g1, width = 9, height = 6, dpi = 300)

g2 <- por_estado %>%
  filter(n >= 10) %>%
  slice_max(indice_amplo, n = 10) %>%
  ggplot(aes(x = reorder(estado, indice_amplo), y = indice_amplo)) +
  geom_col() + coord_flip() +
  labs(x = NULL, y = "Indice amplo (0-100)",
       title = "Estados com maior indice medio na amostra") +
  theme_minimal(base_size = 11)
ggsave("outputs/figuras/top_estados.png", g2, width = 8, height = 5.5, dpi = 300)

# Registro do ambiente
capture.output(sessionInfo(), file = "outputs/sessionInfo.txt")
